# Google OAuth 2.0 Credentials
# 1. Go to Google Cloud Console (https://console.cloud.google.com/)
# 2. Create a new Project and enable the Google+ API.
# 3. Go to APIs & Services > Credentials
# 4. Click Create Credentials > OAuth client ID
# 5. Set Application type to "Web application"
# 6. Add Authorized redirect URI: http://127.0.0.1:5000/login/google/authorized
# 7. Copy the Client ID and Client Secret into the variables below.

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Admin configuration
ADMIN_EMAIL=admin@example.com

# Flask Session Security (generate a random string for production)
SECRET_KEY=dev-secret-change-in-production
